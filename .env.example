# Database — Replace with your PostgreSQL connection strings
# Local runtime: postgresql://postgres:postgres@localhost:5432/coachlms?schema=public
# Supabase runtime on Vercel: postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true
# Supabase migrations: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coachlms?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/coachlms?schema=public"

# NextAuth — Generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# App
NEXT_PUBLIC_APP_NAME="CoachLMS"
